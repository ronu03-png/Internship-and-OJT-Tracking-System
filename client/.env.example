# Frontend environment variables.
# Copy to .env for local overrides, or set in your host (Netlify) dashboard.

# Backend API base URL. Leave unset for local dev (Vite proxies /api to :4000).
# In production set this to your deployed backend, including the /api suffix:
# VITE_API_URL=https://interntrack-api.onrender.com/api

# Optional whole-site password gate. When set, visitors must enter this single
# shared password before the site loads at all. Leave unset to disable.
# VITE_SITE_PASSWORD=mysecretdemo
